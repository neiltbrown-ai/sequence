# Claude — internal tooling key (tracked separately from Sequence user spend).
# Falls back to ANTHROPIC_API_KEY if unset.
SEQ_INTERNAL_ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_API_KEY=

# Image search
SERPER_API_KEY=          # Google Images proxy (serper.dev) — stills of the subject
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=          # b-roll stock video (and stills)
PIXABAY_API_KEY=         # optional 2nd b-roll source (free: pixabay.com/api/docs)

# Video search (optional; video download is opt-in via --allow-video-download + yt-dlp)
YOUTUBE_API_KEY=

# Override where media is written (defaults to ../remotion/public). Set if the
# Remotion tooling lives elsewhere.
# REMOTION_PUBLIC_DIR=/path/to/sequence/tools/remotion/public

PORT=3100
