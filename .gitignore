# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
tools/*/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# claude code local config
.claude/

# local dev shortcut
Start Sequence Dev.command

# typescript
*.tsbuildinfo
next-env.d.ts

# one-off migration proposal artifacts (regenerable via scripts/backfill-case-study-taxonomy.ts)
content/case-study-taxonomy-proposals*.json

# case study audit working artifacts (proposal docs, calibration batches, scratch)
/audit-output/

# remotion video tooling (local-only; large node_modules + rendered mp4s, not part of the deployed app)
/tools/remotion/

# stray render export accidentally dropped into public/videos (the demo/hero mp4s here ARE committed on purpose)
/public/videos/SEQ-TemiCoker-90sec-v1.mp4
