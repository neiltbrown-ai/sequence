# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_LIBRARY_ANNUAL=price_...
STRIPE_PRICE_FULL_ACCESS_MONTHLY=price_...
STRIPE_PRICE_FULL_ACCESS_ANNUAL=price_...

# Anthropic (SEQ_ prefix avoids collision with Claude Code shell env vars)
SEQ_ANTHROPIC_API_KEY=sk-ant-...
ASSESSMENT_AUTO_RELEASE=false

# Resend (transactional email)
RESEND_API_KEY=re_...


# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
